# ── AIBORGZ Security Bot ──
DISCORD_TOKEN=your_discord_bot_token
LOG_CHANNEL=security-log
QUARANTINE_ROLE=Quarantine
PREFIX=!sec
FLAG_THRESHOLD=30
DB_PATH=/data/security.db

# ── IRON DON ──
IRONDON_TOKEN=your_irondon_bot_token
OPENROUTER_API_KEY=your_openrouter_key
IRONDON_CHANNELS=

# ── Rumble Room Gate — Discord side ──
DISCORD_CLIENT_ID=your_bot_application_id
DISCORD_SERVER_ID=your_discord_server_id

# ── Rumble Room Gate — X (Twitter) Developer App ──
X_CLIENT_ID=your_x_oauth2_client_id
X_CLIENT_SECRET=your_x_oauth2_client_secret
X_BEARER_TOKEN=your_x_app_bearer_token
X_CALLBACK_URL=https://YOUR-RAILWAY-URL.up.railway.app/rumble/callback

# ── Rumble Room Gate — server ──
BASE_URL=https://YOUR-RAILWAY-URL.up.railway.app
RUMBLE_OAUTH_PORT=3001
RUMBLE_DB_PATH=/data/rumble-gate.db

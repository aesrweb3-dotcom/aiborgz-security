# AIBORGZ Security Bot — Environment Variables
# Copy this to .env and fill in your values

# Your bot token from Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Channel name where security alerts are posted
LOG_CHANNEL=security-log

# Role name to apply to flagged members
QUARANTINE_ROLE=Quarantine

# Command prefix
PREFIX=!sec

# Risk score threshold to flag a member (0-100)
# 30 = flag if any suspicious signals
# 50 = only flag medium+ risk
# 70 = only flag high risk
FLAG_THRESHOLD=30

# Database file path (Railway uses /data for persistent storage)
DB_PATH=./security.db
